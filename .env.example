# ── OpenCBS Production Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in every value before running:
#   docker compose -f docker-compose-production.yml up -d --build
#
# NEVER commit the populated .env file to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=opencbs
POSTGRES_USER=opencbs_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=opencbs_mq
RABBITMQ_PASSWORD=CHANGE_ME_strong_mq_password

# ── JWT signing secret (min 64 random characters recommended) ─────────────────
JWT_SECRET=CHANGE_ME_very_long_random_string_at_least_64_chars

# ── API JVM tuning (adjust to your EC2 instance size) ────────────────────────
API_HEAP_MAX=512m
API_MEMORY_LIMIT=768M
